{
  "name": "WaveVM-Tailscale",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "remoteUser": "root",
  "containerUser": "root",
  "updateRemoteUserUID": false,
  "capAdd": [
    "NET_ADMIN",
    "NET_RAW"
  ],
  "runArgs": [
    "--privileged",
    "--device=/dev/net/tun:/dev/net/tun",
    "--security-opt=no-new-privileges:false",
    "--security-opt=seccomp=unconfined"
  ],
  "postCreateCommand": "bash -lc 'if ! command -v tailscale >/dev/null 2>&1; then curl -fsSL https://tailscale.com/install.sh | sh; fi'"
}
