{
  "name": "WaveVM-Tailscale",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "remoteUser": "root",
  "containerUser": "root",
  "updateRemoteUserUID": false,
  "privileged": true,
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "capAdd": [
    "NET_ADMIN",
    "NET_RAW"
  ],
  "securityOpt": [
    "no-new-privileges:false",
    "seccomp=unconfined",
    "apparmor=unconfined"
  ],
  "runArgs": [
    "--device=/dev/net/tun:/dev/net/tun"
  ],
  "postCreateCommand": "bash -lc 'if ! command -v tailscale >/dev/null 2>&1; then curl -fsSL https://tailscale.com/install.sh | sh; fi'"
}
